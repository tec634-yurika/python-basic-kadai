        "top = 10      #上辺\n",
        "bottom = 20   #下辺\n",
        "height = 5    #高さ\n",
        "\n",
        "#台形の面積 =（上辺＋下辺）× 高さ ÷ 2\n",
        "trapezoid_area = (top + bottom) * height / 2\n",
        "\n",
        "print(f\"台形の面積は{trapezoid_area}cm²です\")"
