      "source": [
        "import math\n",
        "\n",
        "\"\"\"\n",
        "消費税を加えた金額を返す関数\n",
        "　price：税抜き商品価格\n",
        "　tax  ：消費税\n",
        "\"\"\"\n",
        "def add_tax(price, tax):\n",
        "    # 消費税率を算出する\n",
        "    tax_rate = tax / 100\n",
        "\n",
        "    # 計算結果の小数点以下は切り捨てる\n",
        "    total = math.floor(price * (1 + tax_rate))\n",
        "    return total\n",
        "\n",
        "total_price = add_tax(110, 10)\n",
        "print(f\"商品の価格（税込）は、{total_price}です。\")"
      ],
      "metadata": {
